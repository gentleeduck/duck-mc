              <dict>
                <key>name</key>
                <string>support.type</string>
              </dict>
            </dict>
            <key>end</key>
            <string>```$</string>
            <key>name</key>
            <string>string.quoted.multiline.hurl</string>
          </dict>
          <dict>
            <key>match</key>
            <string>`(\\.|[^\\`])*`</string>
