          <dict>
            <key>begin</key>
            <string>\b(base64|hex),</string>
            <key>beginCaptures</key>
            <dict>
              <key>1</key>
              <dict>
                <key>name</key>
                <string>support.function.name</string>
              </dict>
            </dict>
            <key>contentName</key>
            <string>text.plain</string>
            <key>end</key>
            <string>;</string>
            <key>endCaptures</key>
            <dict>
              <key>0</key>
              <dict>
                <key>name</key>
