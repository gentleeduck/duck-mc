{
	"name": "@gentleduck/md",
	"version": "0.2.0",
	"description": "Native Rust MDX compiler with a velite-shaped TypeScript API",
	"license": "MIT",
	"author": "gentleduck",
	"homepage": "https://github.com/gentleeduck/duck-mc#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gentleeduck/duck-mc.git",
		"directory": "dmc-napi"
	},
	"bugs": {
		"url": "https://github.com/gentleeduck/duck-mc/issues"
	},
	"keywords": [
		"mdx",
		"markdown",
		"compiler",
		"velite",
		"rust",
		"napi",
		"shiki",
		"syntect",
		"katex"
	],
	"type": "module",
	"main": "mod.ts",
	"types": "mod.ts",
	"exports": {
		".": {
			"types": "./mod.ts",
			"default": "./mod.ts"
		}
	},
	"files": [
		"mod.ts",
		"index.js",
		"index.d.ts",
		"*.node",
		"README.md",
		"logo-dark.svg"
	],
	"napi": {
		"name": "dmc",
		"triples": {
			"defaults": true,
			"additional": []
		}
	},
	"scripts": {
		"build": "napi build --platform --release",
		"build:debug": "napi build --platform"
	},
	"dependencies": {
		"unified": "^11",
		"remark-parse": "^11",
		"remark-rehype": "^11",
		"rehype-raw": "^7",
		"rehype-stringify": "^10"
	},
	"devDependencies": {
		"@napi-rs/cli": "^2.18.4",
		"@types/node": "^25",
		"@types/unist": "^3"
	}
}
