            </array>
          </dict>
          <dict>
            <key>begin</key>
            <string>"""</string>
            <key>end</key>
            <string>"""</string>
            <key>name</key>
            <string>string.quoted.triple.basic.block.gdresource</string>
            <key>patterns</key>
            <array>
              <dict>
                <key>match</key>
                <string>\\([\n "/\\bfnrt]|u\h{4}|U\h{8})</string>
                <key>name</key>
                <string>constant.character.escape.gdresource</string>
              </dict>
              <dict>
                <key>match</key>
                <string>\\[^\n"/\\bfnrt]</string>
                <key>name</key>
                <string>invalid.illegal.escape.gdresource</string>
              </dict>
            </array>
          </dict>
          <dict>
            <key>match</key>
            <string>"res://[^"\\]*(?:\\.[^"\\]*)*"</string>
            <key>name</key>
            <string>support.function.any-method.gdresource</string>
          </dict>
          <dict>
            <key>match</key>
            <string>(?&lt;=type=)"[^"\\]*(?:\\.[^"\\]*)*"</string>
