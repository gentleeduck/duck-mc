            <key>name</key>
            <string>constant.character.escape.gdresource</string>
          </dict>
          <dict>
            <key>begin</key>
            <string>"</string>
            <key>end</key>
            <string>"</string>
            <key>name</key>
            <string>string.quoted.double.basic.line.gdresource</string>
