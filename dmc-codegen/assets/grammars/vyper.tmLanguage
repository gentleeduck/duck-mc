          <dict>
            <key>match</key>
            <string>(?&lt;!\.)\b(send|print|breakpoint|selfdestruct|raw_call|raw_log|raw_revert|create_minimal_proxy_to|create_forwarder_to|create_copy_of|create_from_blueprint)\b</string>
            <key>name</key>
