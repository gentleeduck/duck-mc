{
  "name": "@duck/md",
  "version": "0.1.0",
  "type": "module",
  "main": "mod.js",
  "types": "mod.d.ts",
  "exports": {
    ".": {
      "types": "./mod.d.ts",
      "import": "./mod.js",
      "default": "./mod.js"
    }
  },
  "files": ["mod.js", "mod.d.ts", "mod.ts", "index.js", "index.d.ts", "*.node"],
  "napi": {
    "name": "duck-md",
    "triples": {
      "defaults": true,
      "additional": []
    }
  },
  "scripts": {
    "build:rs": "napi build --platform --release",
    "build:ts": "tsc -p tsconfig.json",
    "build": "pnpm build:rs && pnpm build:ts",
    "build:debug": "napi build --platform && pnpm build:ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22",
    "typescript": "^5"
  }
}
