{
  "name": "duck-mc",
  "version": "0.1.0",
  "private": true,
  "description": "Native Rust MDX compiler with a velite-shaped TypeScript API",
  "license": "MIT",
  "author": "gentleduck",
  "homepage": "https://gentleduck.org/duck-md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gentleeduck/duck-mc.git"
  },
  "bugs": {
    "url": "https://github.com/gentleeduck/duck-mc/issues"
  },
  "keywords": [
    "mdx",
    "markdown",
    "compiler",
    "velite",
    "rust",
    "napi"
  ],
  "scripts": {
    "prepare": "husky",
    "fix": "cargo fmt --all",
    "check": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "test": "cargo test --workspace",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:tag": "changeset tag && git push --follow-tags"
  },
  "dependencies": {
    "plist": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "husky": "^9.1.7"
  }
}
